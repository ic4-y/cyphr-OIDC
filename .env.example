# Cyphr-OIDC Bridge Environment Variables
BRIDGE_PORT=8080
BRIDGE_ISSUER_URL=http://localhost:8080
BRIDGE_CLIENT_ID=cyphrmask-poc
BRIDGE_CLIENT_SECRET=dev-secret-change-me
BRIDGE_CALLBACK_URL=http://localhost:8080/callback

# Persistent signing key (path inside container)
# Leave empty to generate a new key on each start
BRIDGE_SIGNING_KEY_PATH=/keys/signing-key.pem

# Registered users (JSON map of thumbprint -> {email, public_key})
# Overrides the default test user. Format:
# BRIDGE_USERS={"<thumbprint>":{"email":"user@example.com","public_key":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}}
BRIDGE_USERS=

# Registered OIDC clients (JSON array of {id, secret, redirect_uris})
# When set, replaces the default client (BRIDGE_CLIENT_ID). Format:
# BRIDGE_CLIENTS=[{"id":"forgejo","secret":"forgejo-secret","redirect_uris":["https://forgejo.example/user/oauth2/Cyphr/callback"]}]
BRIDGE_CLIENTS=
